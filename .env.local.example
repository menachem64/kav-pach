# ──────────────────────────────────────────────────────────────────────────
# קו פח – Environment Variables
# ──────────────────────────────────────────────────────────────────────────
# העתק קובץ זה ל-.env.local ומלא את הערכים.

# קישור ל-Google Sheet (אופציונלי – אם מוגדר, הנתונים יטענו אוטומטית בפתיחת האתר).
# חייב להיות שיתוף ציבורי ("כל מי שיש לו את הקישור יכול לצפות").
# דוגמה:
# GOOGLE_SHEETS_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit#gid=0
GOOGLE_SHEETS_URL=https://docs.google.com/spreadsheets/d/1RBNKiPXOyi0ojXgwRqGNGKasEK_aI90U/edit?usp=sharing&ouid=101531943618844410050&rtpof=true&sd=true

# אותו קישור גם בצד הלקוח (לטעינה אוטומטית ב-UI ללא צורך בהגדרה ידנית):
NEXT_PUBLIC_GOOGLE_SHEETS_URL=https://docs.google.com/spreadsheets/d/1RBNKiPXOyi0ojXgwRqGNGKasEK_aI90U/edit?usp=sharing&ouid=101531943618844410050&rtpof=true&sd=true
